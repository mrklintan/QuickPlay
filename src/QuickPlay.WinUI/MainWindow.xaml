<Window
    x:Class="QuickPlay.WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:QuickPlay.WinUI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="QuickPlay">

    <Grid
        x:Name="RootGrid"
        Padding="24,12,24,20"
        AllowDrop="True"
        Background="#202020"
        DragOver="OnDragOver"
        Drop="OnDrop"
        Loaded="OnLoaded"
        RequestedTheme="Dark"
        RowSpacing="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Spacing="8">
            <MenuBar Margin="-10,0,0,0">
                <MenuBarItem Title="File">
                    <MenuFlyoutItem Text="Open Folder..." KeyboardAcceleratorTextOverride="Ctrl+O" Click="OnChooseFolder" />
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem Text="Exit" Click="OnExit" />
                </MenuBarItem>
                <MenuBarItem Title="Settings">
                    <MenuFlyoutItem Text="Settings..." Click="OnGeneralSettings" />
                    <MenuFlyoutItem Text="Keyboard..." Click="OnShortcutSettings" />
                    <MenuFlyoutItem Text="Playlist Columns..." Click="OnPlaylistColumnsSettings" />
                </MenuBarItem>
                <MenuBarItem Title="About">
                    <MenuFlyoutItem Text="About QuickPlay..." Click="OnAbout" />
                </MenuBarItem>
            </MenuBar>

            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock VerticalAlignment="Center" FontSize="28" FontWeight="SemiBold" Text="QuickPlay" />
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Orientation="Horizontal" Spacing="8">
                    <Button Content="Previous" Click="OnPrevious" />
                    <Button x:Name="PlayPauseButton" Content="Pause" Click="OnPlayPause" />
                    <Button Content="Next" Click="OnNext" />
                </StackPanel>
            </Grid>
        </StackPanel>

        <Border
            Grid.Row="1"
            Padding="18"
            Background="#2B2B2B"
            BorderBrush="#3D3D3D"
            BorderThickness="1"
            CornerRadius="10">
            <Grid ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="420" />
                </Grid.ColumnDefinitions>

                <Grid RowSpacing="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="NowPlayingTitleText" FontSize="24" FontWeight="SemiBold" Text="Nothing playing" TextTrimming="CharacterEllipsis" />
                    <TextBlock x:Name="CurrentFileNameText" Grid.Row="1" Foreground="#9E9E9E" Text="—" TextTrimming="CharacterEllipsis" />
                    <StackPanel Grid.Row="2" Margin="0,7,0,0" Orientation="Horizontal" Spacing="20">
                        <TextBlock x:Name="NowPlayingKeyText" Text="Key —" />
                        <TextBlock x:Name="NowPlayingBpmText" Text="BPM —" />
                        <TextBlock x:Name="NowPlayingEnergyText" Text="Energy —" />
                    </StackPanel>
                </Grid>

                <StackPanel Grid.Column="1" Spacing="8">
                    <Border Padding="12,8" Background="#303030" BorderBrush="#484848" BorderThickness="1" CornerRadius="6">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center" Foreground="#9E9E9E" Text="Artist" />
                            <TextBlock x:Name="NowPlayingArtistText" Grid.Column="1" Text="—" TextTrimming="CharacterEllipsis" />
                        </Grid>
                    </Border>
                    <Border Padding="12,8" Background="#303030" BorderBrush="#484848" BorderThickness="1" CornerRadius="6">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center" Foreground="#9E9E9E" Text="Folder" />
                            <TextBlock x:Name="CurrentFolderText" Grid.Column="1" Text="—" TextTrimming="CharacterEllipsis" />
                        </Grid>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <StackPanel Grid.Row="2" Spacing="5">
            <Border Background="#171717" BorderBrush="#454545" BorderThickness="1" CornerRadius="10">
                <Canvas
                    x:Name="WaveformCanvas"
                    Height="150"
                    PointerPressed="OnWaveformPressed"
                    SizeChanged="OnWaveformSizeChanged" />
            </Border>
            <Grid>
                <TextBlock x:Name="CurrentTimeText" FontWeight="SemiBold" Text="00:00" />
                <TextBlock x:Name="DurationText" HorizontalAlignment="Right" Text="00:00" />
            </Grid>
        </StackPanel>

        <Grid Grid.Row="3" MinHeight="180">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <ScrollViewer
                x:Name="PlaylistHeaderScrollViewer"
                Background="#292929"
                HorizontalScrollBarVisibility="Hidden"
                HorizontalScrollMode="Enabled"
                SizeChanged="OnPlaylistViewportSizeChanged"
                VerticalScrollBarVisibility="Disabled"
                VerticalScrollMode="Disabled">
                <StackPanel x:Name="PlaylistHeaderPanel" Background="#292929" Orientation="Horizontal" />
            </ScrollViewer>
            <ListView
                x:Name="TrackList"
                Grid.Row="1"
                ContainerContentChanging="OnTrackContainerContentChanging"
                ItemsSource="{x:Bind Tracks}"
                Loaded="OnTrackListLoaded"
                ScrollViewer.HorizontalScrollBarVisibility="Auto"
                ScrollViewer.HorizontalScrollMode="Enabled"
                SelectionChanged="OnTrackSelected">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Padding" Value="0" />
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="local:TrackListItemViewModel">
                        <ItemsControl ItemsSource="{x:Bind Cells}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="local:PlaylistCellViewModel">
                                    <Border Width="{x:Bind Width, Mode=OneWay}" Padding="8,5">
                                        <TextBlock
                                            FontStyle="{x:Bind FontStyle, Mode=OneWay}"
                                            FontWeight="{x:Bind FontWeight, Mode=OneWay}"
                                            Text="{x:Bind Text, Mode=OneWay}"
                                            TextTrimming="CharacterEllipsis"
                                            ToolTipService.ToolTip="{x:Bind ToolTipText, Mode=OneWay}" />
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <TextBlock x:Name="StatusText" Grid.Row="4" Foreground="#B8B8B8" Text="Ready. Drop a music folder anywhere in this window." />
    </Grid>
</Window>
