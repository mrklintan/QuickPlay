<Window
    x:Class="QuickPlay.WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:QuickPlay.WinUI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="QuickPlay">

    <Grid
        x:Name="RootGrid"
        Padding="24"
        AllowDrop="True"
        Background="#202020"
        DragOver="OnDragOver"
        Drop="OnDrop"
        Loaded="OnLoaded"
        RequestedTheme="Dark"
        RowSpacing="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock FontSize="28" FontWeight="SemiBold" Text="QuickPlay" />
                <TextBlock x:Name="FolderNameText" Foreground="#B8B8B8" Text="Drop a folder here or choose Open Folder" />
            </StackPanel>
            <StackPanel Grid.Column="1" VerticalAlignment="Center" Orientation="Horizontal" Spacing="8">
                <Button Content="Open Folder" Click="OnChooseFolder" />
                <Button Content="Previous" Click="OnPrevious" />
                <Button x:Name="PlayPauseButton" Content="Pause" Click="OnPlayPause" />
                <Button Content="Next" Click="OnNext" />
            </StackPanel>
        </Grid>

        <Border
            Grid.Row="1"
            Padding="14,10"
            Background="#2B2B2B"
            BorderBrush="#3D3D3D"
            BorderThickness="1"
            CornerRadius="8">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBlock VerticalAlignment="Center" FontWeight="SemiBold" Text="Audition start" />
                <TextBox x:Name="AuditionPositionBox" Width="90" VerticalContentAlignment="Center" PlaceholderText="01:00" />
                <Button Content="Save" Click="OnSaveSettings" />
                <Button Content="Keyboard shortcuts" Click="OnShortcutSettings" />
                <TextBlock x:Name="SettingsMessage" VerticalAlignment="Center" Foreground="#B8B8B8" />
            </StackPanel>
        </Border>

        <Border
            Grid.Row="2"
            Padding="18"
            Background="#2B2B2B"
            BorderBrush="#3D3D3D"
            BorderThickness="1"
            CornerRadius="10">
            <Grid RowSpacing="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock x:Name="NowPlayingTitleText" FontSize="24" FontWeight="SemiBold" Text="Nothing playing" TextTrimming="CharacterEllipsis" />
                <TextBlock x:Name="NowPlayingArtistText" Grid.Row="1" FontSize="16" Foreground="#D0D0D0" Text="—" TextTrimming="CharacterEllipsis" />
                <Grid Grid.Row="2" Margin="0,6,0,0" ColumnSpacing="18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="NowPlayingBpmText" Text="BPM —" />
                    <TextBlock x:Name="NowPlayingKeyText" Grid.Column="1" Text="Key —" />
                    <TextBlock x:Name="CurrentFileNameText" Grid.Column="2" HorizontalAlignment="Right" Foreground="#9E9E9E" Text="—" TextTrimming="CharacterEllipsis" />
                </Grid>
            </Grid>
        </Border>

        <StackPanel Grid.Row="3" Spacing="5">
            <Border
                Background="#171717"
                BorderBrush="#454545"
                BorderThickness="1"
                CornerRadius="10">
                <Canvas
                    x:Name="WaveformCanvas"
                    Height="150"
                    PointerPressed="OnWaveformPressed"
                    SizeChanged="OnWaveformSizeChanged" />
            </Border>
            <Grid>
                <TextBlock x:Name="CurrentTimeText" FontWeight="SemiBold" Text="00:00" />
                <TextBlock x:Name="DurationText" HorizontalAlignment="Right" Text="00:00" />
            </Grid>
        </StackPanel>

        <Grid Grid.Row="4" MinHeight="180">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid Padding="12,7" Background="#292929">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="3*" />
                    <ColumnDefinition Width="70" />
                    <ColumnDefinition Width="70" />
                    <ColumnDefinition Width="70" />
                </Grid.ColumnDefinitions>
                <TextBlock FontWeight="SemiBold" Text="Artist" />
                <TextBlock Grid.Column="1" FontWeight="SemiBold" Text="Title" />
                <TextBlock Grid.Column="2" FontWeight="SemiBold" Text="BPM" />
                <TextBlock Grid.Column="3" FontWeight="SemiBold" Text="Key" />
                <TextBlock Grid.Column="4" FontWeight="SemiBold" Text="Duration" />
            </Grid>
            <ListView
                x:Name="TrackList"
                Grid.Row="1"
                ItemsSource="{x:Bind Tracks}"
                SelectionChanged="OnTrackSelected">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Padding" Value="0" />
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="local:TrackListItemViewModel">
                        <Grid Padding="4,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="3*" />
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="70" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{x:Bind Artist, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                            <TextBlock Grid.Column="1" Text="{x:Bind Title, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                            <TextBlock Grid.Column="2" Text="{x:Bind Bpm, Mode=OneWay}" />
                            <TextBlock Grid.Column="3" Text="{x:Bind InitialKey, Mode=OneWay}" />
                            <TextBlock Grid.Column="4" Text="{x:Bind Duration, Mode=OneWay}" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <TextBlock x:Name="StatusText" Grid.Row="5" Foreground="#B8B8B8" Text="Ready. Drop a music folder anywhere in this window." />
    </Grid>
</Window>
